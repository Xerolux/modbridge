# ModBridge Environment Configuration
# Copy this file to .env and adjust values as needed

# Log level (DEBUG, INFO, WARN, ERROR)
LOG_LEVEL=INFO

# Timezone
TZ=UTC

# Web UI Port
WEB_PORT=:8080

# Multi-user authentication (set to 'true' to enable DB-backed users;
# also requires "multi_user": true in config.json). When enabled, an initial
# admin account is created on first start and its password is logged.
# MODBRIDGE_MULTI_USER=true

# Additional configuration
# GOMAXPROCS=4
# GOGC=100
